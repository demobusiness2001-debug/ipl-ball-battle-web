# Cricket API Configuration
# Using Cricbuzz Live (free, no API key needed)
# Alternative: Get API key from https://cricketdata.org or https://www.entitysport.com/
CRICKET_API_KEY=

# API Provider: 'cricbuzz' (default, free), 'demo', 'cricketdata', or 'entity'
CRICKET_API_PROVIDER=cricbuzz

# Match Configuration (used when no live match found)
MATCH_ID=ipl-demo
MATCH_TITLE=RCB vs SRH
MATCH_TEAMS=RCB,SRH

# Server Ports
PORT=8080

# Game Timing (milliseconds)
PREDICTION_WINDOW_MS=8000
RESULT_PAUSE_MS=1800
